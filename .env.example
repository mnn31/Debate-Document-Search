# Copy to .env and fill in. Do not commit .env.
# The server loads this file automatically when you run npm run dev.

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/debate_vault

# Required for AI: OpenAI API key from https://platform.openai.com/api-keys
# Enables: AI keywords/tags on upload and seed, semantic search, opponent case analysis.
OPENAI_API_KEY=sk-your-key-here

# Optional: OpenAI model (default gpt-4o-mini). Use gpt-4o or gpt-3.5-turbo if you prefer.
# OPENAI_MODEL=gpt-4o-mini

# Optional: bind host (default 0.0.0.0). Use 127.0.0.1 for local-only.
# HOST=127.0.0.1
